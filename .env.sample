#!/usr/bin/env bash
# vim: ft=bash
#
# Deploy-time configuration. Copy to .env (gitignored) and fill in.
# Read ONLY by bin/deploy, which maps these into TF_VAR_* before running
# Terraform. The FastAPI app at runtime does NOT read this file —
# it loads api/.env.{development,test,ci}[.local] instead, driven by the
# ENVIRONMENT variable. Production / staging runtime config arrives via
# Cloud Run env vars set by Terraform.
#
# Two deploy targets share this file:
#   just deploy             → production (default; see PRODUCTION_* keys)
#   just deploy staging     → staging    (see STAGING_* keys)
#
# Local dev uses bin/gctl start and the api/.env.development file — no
# entries in this file affect it.

# ─── Project / region (shared) ────────────────────────────────────────────
PROJECT_ID="sand-castle-486503-d0"
REGION="us-central1"
CLUSTER_NAME="gomoku-cluster"

# ─── Honeycomb (shared by default; staging may override) ──────────────────
# https://ui.honeycomb.io/agentica-group/environments/test/api_keys
HONEYCOMB_INGEST_API_KEY=
# Needed to record deploys in Honeycomb as markers.
HONEYCOMB_CONFIG_API_KEY=
# Optional: per-env override if you want staging traces in a separate dataset.
# STAGING_HONEYCOMB_INGEST_API_KEY=

# ─── Email (password reset, account notifications) ────────────────────────
# Set EMAIL_PROVIDER=sendgrid for real outbound mail; "stdout" (the
# default if omitted) just logs rendered bodies so dev/staging can run
# without a key. EMAIL_FROM must be a SendGrid-verified sender — set up
# at https://app.sendgrid.com/settings/sender_auth/senders.
EMAIL_PROVIDER=stdout
EMAIL_FROM=
EMAIL_FROM_NAME=
# SendGrid Web API key (Mail Send permission). Shared across envs by
# default; override per-env with PRODUCTION_SENDGRID_API_KEY /
# STAGING_SENDGRID_API_KEY if you want isolation.
SENDGRID_API_KEY=
# PRODUCTION_SENDGRID_API_KEY=
# STAGING_SENDGRID_API_KEY=

# ─── Production ───────────────────────────────────────────────────────────
# Pooled Neon DSN (or any managed Postgres connection string).
PRODUCTION_DATABASE_URL="postgresql://USERNAME:PASSWORD@HOSTNAME/gomoku?sslmode=require&channel_binding=require"
# JWT signing secret (generate with `just jwt-secret`).
PRODUCTION_JWT_SECRET="..."
# Custom domain mapped to gomoku-api in production. Run
#   terraform output custom_domain_dns_records
# (in iac/cloud_run/) AFTER the first apply to get the DNS records to add.
# Apex domains (e.g. gomoku.us) need 4 A records — see iac/README.md.
PRODUCTION_CUSTOM_DOMAIN="gomoku.us"

# Backwards-compatible alias for PRODUCTION_CUSTOM_DOMAIN — `bin/deploy`
# falls back to this when PRODUCTION_CUSTOM_DOMAIN is unset, so older
# .env files that only set CUSTOM_DOMAIN keep working.
CUSTOM_DOMAIN="${PRODUCTION_CUSTOM_DOMAIN}"

# ─── Staging ──────────────────────────────────────────────────────────────
# Separate Neon project / branch — staging must NEVER share a DB with prod.
STAGING_DATABASE_URL="postgresql://USERNAME:PASSWORD@STAGING_HOSTNAME/gomoku?sslmode=require&channel_binding=require"
# Generate with `just jwt-secret` — distinct from prod so a leaked staging
# token never grants production access.
STAGING_JWT_SECRET="..."
# Custom domain for the staging stack.
STAGING_CUSTOM_DOMAIN="staging.gomoku.games"
