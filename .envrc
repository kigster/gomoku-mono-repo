# vim: ft=bash
PATH_add .
PATH_add bin

command -v brew >/dev/null && {
  PATH_add $(brew --prefix)/bin
}

# Export every key in .env into the shell. Safe: everything in .env uses a
# deploy-only namespace (PRODUCTION_DATABASE_URL, PRODUCTION_JWT_SECRET,
# HONEYCOMB_*, PROJECT_ID, REGION, CLUSTER_NAME) — none of which collide with
# the runtime config Pydantic reads inside the FastAPI app.
dotenv_if_exists .env

dotenv_if_exists .env.local

