#!/usr/bin/env bash
# vim: ft=bash

# GOMOKUD_BINARY/GOMOKUD_EXECUTABLE/GOMOKUD_BINARY_REGEX can be set in the
# environment (e.g. by bin/gctl) to point at a different daemon — the Rust
# port is invoked as GOMOKUD_BINARY=gomoku-httpd-rust. Defaults preserve the
# original C engine behavior.
: "${GOMOKUD_BINARY:=gomoku-httpd}"
: "${GOMOKUD_EXECUTABLE:=${GOMOKUD_BINARY}}"

command -V "${GOMOKUD_EXECUTABLE}" >/dev/null 2>&1 || export GOMOKUD_EXECUTABLE="./${GOMOKUD_BINARY}"

# Default regex isolates each binary: the C binary is matched with a
# trailing non-dash so "gomoku-httpd-rust" never collides with it. Callers
# managing the Rust binary set GOMOKUD_BINARY_REGEX to "[g]omoku-httpd-rust".
if [[ "${GOMOKUD_BINARY}" == "gomoku-httpd-rust" ]]; then
  : "${GOMOKUD_BINARY_REGEX:=[g]omoku-httpd-rust}"
else
  : "${GOMOKUD_BINARY_REGEX:=[g]omoku-httpd($|[^-])}"
fi
export GOMOKUD_BINARY GOMOKUD_EXECUTABLE GOMOKUD_BINARY_REGEX

DEFAULT_HOST="0.0.0.0"
DEFAULT_PORT=9500
DEFAULT_FLAGS="-L debug -l log/${GOMOKUD_BINARY}.log"

flag_verbose=false

declare -i CPU_CORES=0
CPU_CORES=$(getconf _NPROCESSORS_ONLN)
export CPU_CORES

function daemons-count() {
  (daemons-show || echo 0) | wc -l | tr -d ' '
}

# shellcheck disable=SC2120
function daemons-show() {
  if [[ -z "$1" ]]; then
    echo "All ${GOMOKUD_BINARY} processes:"
    ps -ef | grep -E "${GOMOKUD_BINARY_REGEX}" | grep -v grep
  else
    ps -ef "$1" r | grep -E "${GOMOKUD_BINARY_REGEX}" | grep -v grep | grep -v "grep" | $1
  fi
}

function usage() {
  echo "USAGE:"
  echo "   gomoku-httpd-ctl start [ -w | --workers <workers> ] "
  echo "                    stop"
  echo "                    show"
  echo "                    htop"
  echo "                    help"
  echo ""
  echo "DESCRIPTION:"
  echo "   Starts ${GOMOKUD_BINARY} processes equal to the number of CPU cores."
  echo "   listening on the port starting with the first argument, default is 9900."
}

function parse-argv() {
  [[ -z "$*" ]] && usage && exit 0
  local -i workers="$CPU_CORES"

  while :; do
    case $1 in
    start)
      shift
      [[ $1 =~ ^-w$ ]] && shift
      [[ $1 =~ ^[0-9]+$ ]] && workers="$1" && shift
      daemons-start "$workers"
      ;;
    stop)
      shift
      daemons-stop "$@"
      ;;
    show | status)
      shift
      daemons-status "$1"
      shift
      ;;
    htop)
      shift
      command -v htop >/dev/null 2>&1 ||
        {
          echo "htop is not installed. Please install it first." >&2
          exit 1
        }
      daemons-htop "$@"
      ;;
    -h | --help | help)
      shift
      usage
      exit 0
      ;;
    -v | --verbose)
      flag_verbose=true
      shift
      ;;
    --) # End of all options; anything after will be passed to the action function
      shift
      break
      ;;
    -?*)
      printf 'WARN: Unknown option (ignored): %s\n' "$1" >&2
      exit 127
      shift
      ;;
    *)
      [[ -z "$1" ]] && break
      shift
      ;;
    esac
  done
}

function daemons-htop() {
  htop -F ${GOMOKUD_BINARY}
}

function daemons-start() {
  local nproc="${1}"
  local port hapoxy_port
  local i
  local cmd

  ${flag_verbose} && echo -e "${txtylw}Starting ${nproc} ${GOMOKUD_BINARY} processes...${clr}"

  # Auto-build the missing binary only for the C engine. The Rust port has
  # to be built deliberately via `just build-rust` from the monorepo root.
  if [[ ! -x ${GOMOKUD_EXECUTABLE} && ! -x ${GOMOKUD_BINARY} ]]; then
    case "${GOMOKUD_BINARY}" in
    gomoku-httpd) make -C gomoku-c install ;;
    *)
      echo "ERROR: ${GOMOKUD_BINARY} not found. Run 'just build-rust' from the monorepo root." >&2
      return 1
      ;;
    esac
  fi

  mkdir -p log

  # GOMOKUD_BACKGROUND=1 (set by gctl when the rust engine is selected)
  # background-launches each worker. The C binary daemonizes itself via
  # -d (forks); the rust binary's -d is a no-op, so we have to background
  # it from the shell or this loop would block on the first iteration.
  # Defaults to 0 to preserve C-engine behavior.
  local background="${GOMOKUD_BACKGROUND:-0}"

  for ((i = 0; i < nproc; i++)); do
    port=$((DEFAULT_PORT + i))
    haproxy_port=$((DEFAULT_PORT + i + 100))
    cmd="${GOMOKUD_EXECUTABLE} -b ${DEFAULT_HOST}:${port} -a ${haproxy_port} -d ${DEFAULT_FLAGS}"

    ${flag_verbose} && echo -e -n "${txtgrn}booting: [${cmd}] ... ${clr}"
    if [[ "${background}" == "1" ]]; then
      # Detach via nohup + & + disown so the worker survives this script
      # exiting and we never block on its lifetime.
      nohup bash -c "${cmd}" </dev/null &>/dev/null &
      disown
    else
      eval "${cmd}" &>/dev/null
    fi
    ${flag_verbose} && echo -e "with PID ${txtpur}$!${clr}, exit code $?"
  done

  count_end=$(daemons-count)

  ${flag_verbose} && echo -e "${txtylw}Started $((count_end - count_start)) ${GOMOKUD_BINARY} processes.${clr}"
  ${flag_verbose} && echo -e "${txtgrn}Total running ${GOMOKUD_BINARY} processes: ${bldylw}${count_end}${clr}."
}

function daemons-stop() {
  local count=$(daemons-count)

  if [[ ${count} -gt 0 ]]; then
    ${flag_verbose} && echo -e "${txtylw}Found ${count} processes running, stopping them...${clr}"
    # -x: exact-name match, so killing "gomoku-httpd" doesn't also kill
    # "gomoku-httpd-rust" (and vice versa).
    pkill -9 -x "${GOMOKUD_BINARY}"
  else
    ${flag_verbose} && echo -e "${txtgrn}No ${GOMOKUD_BINARY} processes found, nothing to stop.${clr}"
  fi

  count=$(daemons-count)
  ${flag_verbose} && echo -e "Currently remaining ${GOMOKUD_BINARY} processes: ${bldgrn}${count}${clr}"
}

function daemons-status() {
  daemons-show "$@"
}

function main() {
  parse-argv "$@"
}

main "$@"
